    function jxDetectLang() {
        const s = localStorage.getItem('jxLang');
        if (s && JX_T[s]) return s;
        const nav = (navigator.language || 'es').split('-')[0].toLowerCase();
        return JX_T[nav] ? nav : 'es';
    }

    function jxApply(lang) {
        const t = JX_T[lang] || JX_T['es'];
        document.querySelectorAll('[data-i18n]').forEach(el => {
            const k = el.dataset.i18n;
            if (t[k] !== undefined) el.textContent = t[k];
        });
        document.querySelectorAll('[data-i18n-ph]').forEach(el => {
            const k = el.dataset.i18nPh;
            if (t[k] !== undefined) el.placeholder = t[k];
        });
        var sel = document.getElementById('jxLangSel');
        if (sel) sel.value = lang;
        var selM = document.getElementById('jxLangSelM');
        if (selM) selM.value = lang;
        document.documentElement.lang = lang;
    }

    function jxSetLang(lang) {
        localStorage.setItem('jxLang', lang);
        jxApply(lang);
    }

    (function(){
        var s = localStorage.getItem('jxTheme');
        var mq = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (s === 'dark' || (s === null && mq)) document.documentElement.classList.add('dark');
    })();
    </script>
