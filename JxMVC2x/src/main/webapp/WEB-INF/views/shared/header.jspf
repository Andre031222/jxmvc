<%@page pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>${empty title ? 'JxMVC' : title}</title>
    <link rel="icon" type="image/svg+xml"  href="${pageContext.request.contextPath}/assets/jxlogo.svg?v=3">
    <link rel="icon" type="image/png"      href="${pageContext.request.contextPath}/assets/jxlogo.png?v=3" sizes="192x192">
    <link rel="apple-touch-icon"           href="${pageContext.request.contextPath}/assets/jxlogo.png?v=3">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <script src="${pageContext.request.contextPath}/assets/js/tailwind.cdn.js"></script>
    <script>
    tailwind.config = {
        darkMode: 'class',
        theme: {
            extend: {
                fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui'] },
                colors: {
                    apple:   '#087CFA',
                    ink:     '#1d1d1f',
                    muted:   '#6e6e73',
                    surface: '#f5f5f7',
                    jxo:     '#FC801D',
                    jxr:     '#FE2857',
                    jxv:     '#5A63D6'
                }
            }
        }
    }
    </script>
    <style>
        .jx-reveal { opacity:0; transform:translateY(10px); animation:jxIn .5s cubic-bezier(.22,1,.36,1) forwards; }
        .jx-delay-1{animation-delay:.05s} .jx-delay-2{animation-delay:.1s}
        .jx-delay-3{animation-delay:.16s} .jx-delay-4{animation-delay:.24s}
        @keyframes jxIn { to { opacity:1; transform:translateY(0) } }

        .nav-link { position:relative; }
        .nav-link.active { color:#087CFA !important; }
        .nav-link.active::after {
            content:''; position:absolute; bottom:-2px; left:4px; right:4px;
            height:2px; background:#087CFA; border-radius:2px;
        }

        .jx-tab { color:#6e6e73; }
        .dark .jx-tab { color:#636366; }
        .jx-tab:hover { color:#1d1d1f; }
        .dark .jx-tab:hover { color:#e5e5ea; }
        .jx-tab.jx-tab-active { color:#087CFA; }
        .dark .jx-tab.jx-tab-active { color:#5ac8fa; }
        .jx-tab.jx-tab-active svg { stroke-width:2.4; }

        code { font-family:'Menlo','Consolas','Monaco',monospace; }

        /* Gradient text utility */
        .jx-grad {
            background: linear-gradient(100deg, #FC801D 0%, #087CFA 55%, #5A63D6 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Select language */
        select option { background: #fff; color: #1d1d1f; }
    </style>

    <%-- ── Translations ─────────────────────────────────────────────── --%>
