<body class="bg-surface dark:bg-[#0a0a0f] text-ink dark:text-[#f5f5f7] min-h-screen font-sans antialiased">

<%-- ══ Nav ════════════════════════════════════════════════════════════ --%>
<header class="sticky top-0 z-50 bg-[rgba(245,245,247,0.88)] dark:bg-[rgba(10,10,15,0.90)] backdrop-blur-2xl border-b border-black/[0.07] dark:border-white/[0.06]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-12 flex items-center justify-between gap-3">

        <a href="${pageContext.request.contextPath}/" class="flex items-center gap-2 shrink-0">
            <svg width="24" height="24" viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
                <defs>
                    <linearGradient x1="37%" y1="51%" x2="178%" y2="42%" id="hna">
                        <stop stop-color="#FC801D" offset="9%"/>
                        <stop stop-color="#577DB3" offset="41%"/>
                        <stop stop-color="#087CFA" offset="59%"/>
                    </linearGradient>
                    <linearGradient x1="74%" y1="115%" x2="36%" y2="1%" id="hnb">
                        <stop stop-color="#FE2857" offset="0%"/>
                        <stop stop-color="#386CDA" offset="44%"/>
                        <stop stop-color="#087CFA" offset="100%"/>
                    </linearGradient>
                    <linearGradient x1="29%" y1="24%" x2="82%" y2="130%" id="hnc">
                        <stop stop-color="#FE2857" offset="0%"/>
                        <stop stop-color="#5A63D6" offset="79%"/>
                        <stop stop-color="#087CFA" offset="100%"/>
                    </linearGradient>
                </defs>
                <path fill="url(#hna)" d="M40.5 180.6 2.9 150.8l22.1-41 33.3 11.1z"/>
                <path fill="#087CFA" d="m256 68.2-4.6 148.3-98.6 39.5-53.7-34.7z"/>
                <path fill="url(#hnb)" d="m256 68.2-48.8 47.6L144.5 39l31-34.8z"/>
                <path fill="url(#hnc)" d="m99.1 221.3-78.5 28.4 16.5-57.5 21.2-71.3L0 101.4 37.1 0l83.8 9.9 86.3 105.9z"/>
                <text x="128" y="125" text-anchor="middle" font-family="Segoe UI,Arial,sans-serif" font-size="75" font-weight="900" fill="white">Jx</text>
                <text x="128" y="165" text-anchor="middle" font-family="Segoe UI,Arial,sans-serif" font-size="22" font-weight="bold" fill="white" letter-spacing="2">MVC</text>
            </svg>
            <span class="font-semibold text-sm text-ink dark:text-[#f5f5f7]">JxMVC</span>
        </a>

        <nav class="hidden md:flex items-center gap-0.5 flex-1 justify-center">
            <a href="${pageContext.request.contextPath}/"
               class="nav-link px-3 py-1.5 rounded-lg text-sm text-muted dark:text-[#86868b] hover:text-ink dark:hover:text-[#f5f5f7] transition-colors"
               data-i18n="nav.home">Inicio</a>
            <a href="${pageContext.request.contextPath}/home/about"
               class="nav-link px-3 py-1.5 rounded-lg text-sm text-muted dark:text-[#86868b] hover:text-ink dark:hover:text-[#f5f5f7] transition-colors"
               data-i18n="nav.about">About</a>
            <a href="${pageContext.request.contextPath}/home/docs"
               class="nav-link px-3 py-1.5 rounded-lg text-sm text-muted dark:text-[#86868b] hover:text-ink dark:hover:text-[#f5f5f7] transition-colors"
               data-i18n="nav.docs">Docs</a>
            <a href="${pageContext.request.contextPath}/home/downloads"
               class="nav-link px-3 py-1.5 rounded-lg text-sm text-muted dark:text-[#86868b] hover:text-ink dark:hover:text-[#f5f5f7] transition-colors"
               data-i18n="nav.downloads">Descargas</a>
            <a href="${pageContext.request.contextPath}/home/errors"
               class="nav-link px-3 py-1.5 rounded-lg text-sm text-muted dark:text-[#86868b] hover:text-ink dark:hover:text-[#f5f5f7] transition-colors"
               data-i18n="nav.errors">Errores</a>
        </nav>

        <div class="flex items-center gap-1.5 shrink-0">

            <%-- Language — compact select --%>
            <div class="hidden sm:flex items-center relative">
                <select id="jxLangSel" onchange="jxSetLang(this.value)"
                    class="appearance-none bg-transparent text-[10px] font-mono font-medium tracking-widest text-muted dark:text-[#636366] border border-black/[0.08] dark:border-white/[0.08] rounded-lg pl-2.5 pr-6 py-1.5 cursor-pointer focus:outline-none hover:border-black/[0.15] dark:hover:border-white/[0.15] transition-colors">
                    <option value="es">ES</option>
                    <option value="en">EN</option>
                    <option value="pt">PT</option>
                    <option value="ru">RU</option>
                    <option value="fr">FR</option>
                </select>
                <svg class="absolute right-1.5 top-1/2 -translate-y-1/2 w-3 h-3 text-muted dark:text-[#636366] pointer-events-none" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
            </div>

            <%-- Theme --%>
            <button onclick="jxToggleTheme()"
                    class="w-8 h-8 flex items-center justify-center rounded-lg text-muted dark:text-[#86868b] hover:bg-black/[0.06] dark:hover:bg-white/[0.06] transition-colors"
                    aria-label="Cambiar tema">
                <svg class="hidden dark:block w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                </svg>
                <svg class="dark:hidden w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
            </button>

            <%-- Hamburger --%>
            <button onclick="jxMenuToggle()" id="jxBurger"
                    class="md:hidden w-8 h-8 flex items-center justify-center rounded-lg hover:bg-black/[0.06] dark:hover:bg-white/[0.06] transition-colors">
                <svg class="w-4 h-4 text-muted dark:text-[#86868b]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </div>
    </div>

    <%-- Mobile menu --%>
    <div id="jxMobileNav"
         class="hidden md:hidden bg-[rgba(245,245,247,0.97)] dark:bg-[rgba(10,10,15,0.97)] backdrop-blur-2xl border-t border-black/[0.06] dark:border-white/[0.06]">
        <div class="max-w-6xl mx-auto px-4 py-3 space-y-0.5">
            <a href="${pageContext.request.contextPath}/"       class="flex px-3 py-2.5 rounded-xl text-sm text-muted dark:text-[#86868b] hover:text-ink dark:hover:text-[#f5f5f7] hover:bg-black/[0.05] dark:hover:bg-white/[0.05] transition-colors" data-i18n="nav.home">Inicio</a>
            <a href="${pageContext.request.contextPath}/home/about"   class="flex px-3 py-2.5 rounded-xl text-sm text-muted dark:text-[#86868b] hover:text-ink dark:hover:text-[#f5f5f7] hover:bg-black/[0.05] dark:hover:bg-white/[0.05] transition-colors" data-i18n="nav.about">About</a>
            <a href="${pageContext.request.contextPath}/home/docs"    class="flex px-3 py-2.5 rounded-xl text-sm text-muted dark:text-[#86868b] hover:text-ink dark:hover:text-[#f5f5f7] hover:bg-black/[0.05] dark:hover:bg-white/[0.05] transition-colors" data-i18n="nav.docs">Docs</a>
            <a href="${pageContext.request.contextPath}/home/downloads" class="flex px-3 py-2.5 rounded-xl text-sm text-muted dark:text-[#86868b] hover:text-ink dark:hover:text-[#f5f5f7] hover:bg-black/[0.05] dark:hover:bg-white/[0.05] transition-colors" data-i18n="nav.downloads">Descargas</a>
            <a href="${pageContext.request.contextPath}/home/errors"  class="flex px-3 py-2.5 rounded-xl text-sm text-muted dark:text-[#86868b] hover:text-ink dark:hover:text-[#f5f5f7] hover:bg-black/[0.05] dark:hover:bg-white/[0.05] transition-colors" data-i18n="nav.errors">Errores</a>
            <div class="pt-3 mt-1 border-t border-black/[0.06] dark:border-white/[0.06] flex items-center gap-2">
                <span class="text-[10px] font-mono text-muted dark:text-[#636366]">Idioma</span>
                <div class="relative">
                    <select id="jxLangSelM" onchange="jxSetLang(this.value);jxMenuToggle()"
                        class="appearance-none bg-transparent text-[10px] font-mono font-medium tracking-widest text-muted dark:text-[#636366] border border-black/[0.08] dark:border-white/[0.08] rounded-lg pl-2.5 pr-6 py-1.5 cursor-pointer focus:outline-none">
                        <option value="es">ES</option>
                        <option value="en">EN</option>
                        <option value="pt">PT</option>
                        <option value="ru">RU</option>
                        <option value="fr">FR</option>
                    </select>
                    <svg class="absolute right-1.5 top-1/2 -translate-y-1/2 w-3 h-3 text-muted dark:text-[#636366] pointer-events-none" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
                </div>
            </div>
        </div>
    </div>
</header>

